// Prisma schema for Riyaz's portfolio
// Run `npx prisma db push` after setting DATABASE_URL in .env

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  summary     String   // short one-liner for cards
  description String   // long-form, shown on detail page
  techStack   String[] // e.g. ["Next.js", "PostgreSQL"]
  metrics     String[] // e.g. ["Cut insight time by 70%"]
  githubUrl   String?
  liveUrl     String?
  imageUrl    String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Experience {
  id        String   @id @default(uuid())
  company   String
  role      String
  duration  String   // e.g. "2025 | 4 Months"
  type      String   // "internship" | "virtual" | "other"
  bullets   String[]
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Skill {
  id        String   @id @default(uuid())
  name      String
  category  String   // "Frontend" | "Backend" | "Database" | "Tools" | "AI & APIs" etc.
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}
